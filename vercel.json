{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "pawbandhan",
  "installCommand": "npm install --omit=dev",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "web_app",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend_api/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
