{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "pawbandhan",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "web_app",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pawbandhan-api.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://pawbandhan-api.onrender.com/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
