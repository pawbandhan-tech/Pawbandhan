# Copy to .env and fill in values (never commit .env)

# Neon PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Server
PORT=5000

# Admin sign-in (required in production — never commit real passwords)
ADMIN_EMAIL=admin@pawbandhan.com
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

# Email (optional — OTP/notifications)
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=

# Payments (optional)
RZP_KEY_ID=
RZP_KEY_SECRET=

# Firebase admin (optional — path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=
