{
  "name": "pawbandhan-rider",
  "version": "1.0.0",
  "description": "PawBandhan Rider App - Animal Rescue Platform",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:web && npx cap sync",
    "build:web": "cp ../web_app/rider_app.html www/index.html",
